# ModelScope 配置
MODELSCOPE_API_KEY=
MODELSCOPE_API_BASE=https://api-inference.modelscope.cn/v1
MODELSCOPE_MODEL_ID=
MODELSCOPE_VISION_MODEL_ID=

# 数据库配置
DATABASE_URL=mysql+aiomysql://root:123456@localhost:3306/fastagent
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL=
REDIS_MESSAGE_TTL=

# MCP 服务配置
MCP_SERVER_URL=http://localhost:8001

# 日志配置
LOG_LEVEL=INFO

# FastAPI 应用配置
APP_TITLE=FastAgent System
APP_DESCRIPTION=A powerful Agent system built with FastAPI and LangChain
APP_VERSION=1.0.0

# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_RELOAD=True

# Agent 配置
AGENT_TEMPERATURE=0.3
AGENT_MAX_ITERATIONS=10

# 数据库工具配置
DB_TOOL_NAME=database_query
DB_TOOL_DESCRIPTION=Execute SQL queries on database. Use this tool whenever you need to query database information. Example: 'SELECT * FROM user' to get all user information.
DB_QUERY_LIMIT=100
DB_QUERY_MAX_LENGTH=1000

# MCP 工具配置
MCP_TOOL_NAME=mcp_tool
MCP_TOOL_DESCRIPTION=Execute MCP (Model Context Protocol) tools to perform various tasks
MCP_REQUEST_TIMEOUT=30.0

# 地图 API 配置
AMAP_API_KEY=
AMAP_API_BASE=

# 邮箱配置
EMAIL_FROM=
SMTP_SERVER=smtp.qq.com  # 例如QQ邮箱SMTP服务器
SMTP_PORT=587            # 通常是587或465
SMTP_USERNAME=  
SMTP_PASSWORD=           # 授权码（非登录密码）
